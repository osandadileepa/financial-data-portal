# Railway provides DATABASE_URL automatically (postgresql://...).  This
# template uses the asyncpg scheme.  For local dev, change to your own
# PostgreSQL connection string.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/financial_portal

# On Railway you can leave DATABASE_URL unset — it will be injected
# as 'postgresql://...' and the app converts it to asyncpg syntax.

SECRET_KEY=change-this-to-a-random-secret-key
CANVA_API_KEY=
